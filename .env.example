# CFG Eval — environment
# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.

# Required — your OpenAI API key. Get one at https://platform.openai.com/api-keys
# Needs access to GPT-5 (the Context-Free Grammar feature is GPT-5 only).
OPENAI_API_KEY=

# Optional — override the model. Defaults to gpt-5.
#   gpt-5        balanced default
#   gpt-5-mini   lower cost, still supports CFG
#   gpt-5-nano   cheapest, smallest — useful for eval comparisons
# OPENAI_MODEL=gpt-5

# Required — ClickHouse Cloud connection. Get these from your service's
# "Connect" panel in https://console.clickhouse.cloud
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# The database holding the NYC Taxi sample dataset (default name when loaded
# via the Cloud console's "Add sample data" flow).
CLICKHOUSE_DATABASE=nyc_taxi

# Optional — Raindrop tracing. When set, every /api/query request is traced to
# Raindrop as an `nl_to_sql` event (NL question in, generated SQL out, with
# latency/token/row-count properties), plus a NEGATIVE signal for execution
# failures, empty results, and generation failures. Leave blank to disable —
# tracing is a silent no-op without a key. This is the WRITE / ingestion key,
# which is distinct from the Query (read) API key. Get it from
# https://auth.raindrop.ai/org/api_keys
RAINDROP_WRITE_KEY=

# Optional — Raindrop Query (read) key, used only by scripts/build-eval-set.ts
# to pull traced failures back out and turn them into candidate eval cases.
# Distinct from RAINDROP_WRITE_KEY above; not needed to run the app or tracing.
RAINDROP_QUERY_API_KEY=
